# ==========================================================================
# .dockerignore — ProyectoODOO
# Evita enviar archivos locales al contexto de build/imagen de Docker.
# Nota: el módulo se monta como volumen (ver docker-compose.yml), por lo que
# esto solo afecta al contexto de construcción, no al volumen montado.
# ==========================================================================

# --- Skills locales / lockfile ---
.agents/
skills-lock.json

# --- Cachés de Python ---
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Entornos virtuales / variables de entorno ---
.venv/
venv/
env/
.env

# --- Logs y temporales ---
*.log
*.tmp

# --- Basura del sistema operativo ---
.DS_Store
Thumbs.db

# --- IDEs / editores ---
.idea/
.vscode/

# --- Node / builds / distribuciones ---
node_modules/
dist/
build/

# --- Archivos comprimidos ---
*.zip
*.tar
*.tar.gz

# --- Control de versiones ---
.git/
.gitignore
