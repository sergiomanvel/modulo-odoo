<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_quick_quote_wizard_form" model="ir.ui.view">
        <field name="name">quick.quote.wizard.form</field>
        <field name="model">quick.quote.wizard</field>
        <field name="arch" type="xml">
            <form string="Asistente de presupuesto rápido">
                <sheet>
                    <div class="oe_title">
                        <h1>Asistente de presupuesto rápido</h1>
                        <p class="text-muted">
                            Genera líneas de presupuesto a partir de una plantilla según el tipo de servicio.
                        </p>
                    </div>
                    <group>
                        <group>
                            <field name="request_id"
                                   options="{'no_create': True}"
                                   readonly="context.get('default_request_id', False)"/>
                            <field name="type_id" options="{'no_create': True}"/>
                            <field name="mode" widget="radio"/>
                        </group>
                        <group string="Totales de la plantilla">
                            <field name="preview_cost"/>
                            <field name="preview_price"/>
                            <field name="preview_margin"/>
                            <field name="preview_margin_percent" string="Margen %"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <separator string="Plantilla recomendada"/>
                    <field name="template_line_ids" nolabel="1">
                        <tree string="Líneas de la plantilla" create="false" edit="false" delete="false">
                            <field name="line_type"/>
                            <field name="name"/>
                            <field name="quantity"/>
                            <field name="unit_cost"/>
                            <field name="unit_price"/>
                            <field name="subtotal_cost" sum="Coste"/>
                            <field name="subtotal_price" sum="Precio"/>
                            <field name="currency_id" column_invisible="1"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="action_apply" string="Aplicar al presupuesto" type="object"
                            class="oe_highlight" data-hotkey="q"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_quick_quote_wizard" model="ir.actions.act_window">
        <field name="name">Presupuesto rápido</field>
        <field name="res_model">quick.quote.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
