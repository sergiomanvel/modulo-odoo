<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!-- Vista lista                                                       -->
    <!-- ================================================================ -->
    <record id="view_service_request_tree" model="ir.ui.view">
        <field name="name">service.request.tree</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <tree string="Solicitudes" sample="1"
                  decoration-danger="is_overdue"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="title" optional="show"/>
                <field name="type_id" optional="show"/>
                <field name="user_id" optional="show" widget="many2one_avatar_user"/>
                <field name="priority" widget="priority" optional="show"/>
                <field name="date_request" optional="hide"/>
                <field name="date_deadline" optional="show"/>
                <field name="total_cost" optional="hide"/>
                <field name="total_price" sum="Total" optional="show"/>
                <field name="margin_amount" optional="hide"/>
                <field name="margin_percent" string="Margen %" optional="show"/>
                <field name="margin_category" widget="badge" optional="show"
                       decoration-success="margin_category == 'healthy'"
                       decoration-info="margin_category == 'tight'"
                       decoration-warning="margin_category == 'low'"
                       decoration-danger="margin_category in ('critical', 'unprofitable')"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('pending', 'quoted')"
                       decoration-success="state in ('accepted', 'in_progress', 'done')"
                       decoration-muted="state == 'cancelled'"/>
                <field name="is_overdue" column_invisible="1"/>
                <field name="currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Vista formulario (statusbar, smart buttons, notebook, chatter)   -->
    <!-- ================================================================ -->
    <record id="view_service_request_form" model="ir.ui.view">
        <field name="name">service.request.form</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <form string="Solicitud de servicio">
                <header>
                    <button name="action_confirm" string="Confirmar" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_quote" string="Presupuestar" type="object"
                            class="oe_highlight" invisible="state != 'pending'"/>
                    <button name="action_accept" string="Aceptar" type="object"
                            class="oe_highlight" invisible="state != 'quoted'"/>
                    <button name="action_start" string="Iniciar" type="object"
                            class="oe_highlight" invisible="state != 'accepted'"/>
                    <button name="action_done" string="Completar" type="object"
                            class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_open_quick_quote_wizard" string="Presupuesto rápido"
                            type="object" icon="fa-magic"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_cancel" string="Cancelar" type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft" string="Restablecer a borrador"
                            type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,quoted,accepted,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-list-ul" type="object"
                                name="action_view_quote_lines">
                            <field name="quote_line_count" widget="statinfo" string="Líneas"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-percent" type="object"
                                name="action_view_quote_lines">
                            <field name="margin_percent" widget="statinfo" string="Margen %"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="No rentable" bg_color="text-bg-danger"
                            invisible="margin_category != 'unprofitable'"/>
                    <widget name="web_ribbon" title="Vencida" bg_color="text-bg-warning"
                            invisible="not is_overdue"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <label for="title" class="oe_edit_only"/>
                        <h2><field name="title" placeholder="Ej. Reparación avería línea cocina"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="type_id"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="date_request"/>
                            <field name="date_deadline"/>
                            <field name="margin_category" widget="badge"
                                   decoration-success="margin_category == 'healthy'"
                                   decoration-info="margin_category == 'tight'"
                                   decoration-warning="margin_category == 'low'"
                                   decoration-danger="margin_category in ('critical', 'unprofitable')"/>
                            <field name="is_overdue" invisible="1"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id" invisible="1" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Líneas de presupuesto" name="lines">
                            <field name="quote_line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="line_type"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="unit_cost"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal_cost" sum="Coste"/>
                                    <field name="subtotal_price" sum="Precio"/>
                                    <field name="margin" sum="Beneficio"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                            <group class="oe_subtotal_footer" name="totals">
                                <field name="total_cost"/>
                                <field name="total_price"/>
                                <field name="margin_amount"/>
                                <field name="margin_percent" string="Margen %"/>
                            </group>
                        </page>
                        <page string="Cliente" name="customer">
                            <group>
                                <group string="Datos del cliente">
                                    <field name="partner_id" readonly="1"/>
                                    <field name="partner_phone"/>
                                    <field name="partner_email"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notas" name="notes">
                            <separator string="Descripción del trabajo"/>
                            <field name="description"
                                   placeholder="Descripción detallada del trabajo a realizar..."/>
                            <separator string="Notas internas"/>
                            <field name="internal_note"
                                   placeholder="Notas internas (no visibles para el cliente)..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Vista kanban                                                      -->
    <!-- ================================================================ -->
    <record id="view_service_request_kanban" model="ir.ui.view">
        <field name="name">service.request.kanban</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="title"/>
                <field name="type_id"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="margin_category"/>
                <field name="margin_percent"/>
                <field name="total_price"/>
                <field name="is_overdue"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <field name="user_id"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click #{record.is_overdue.raw_value ? 'oe_kanban_color_1' : ''}">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="partner_id"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="name"/> · <field name="title"/>
                                    </small>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <span t-if="record.type_id.value" class="badge rounded-pill text-bg-light">
                                    <field name="type_id"/>
                                </span>
                                <div class="mt-2">
                                    <span t-attf-class="badge #{record.margin_category.raw_value == 'healthy' ? 'text-bg-success' : (record.margin_category.raw_value == 'tight' ? 'text-bg-info' : ((record.margin_category.raw_value == 'critical' || record.margin_category.raw_value == 'unprofitable') ? 'text-bg-danger' : 'text-bg-warning'))}">
                                        <field name="margin_category"/> ·
                                        <t t-esc="record.margin_percent.value"/>%
                                    </span>
                                    <span t-if="record.is_overdue.raw_value" class="badge text-bg-danger ms-1">
                                        Vencida
                                    </span>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <strong><field name="total_price" widget="monetary"/></strong>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="activity_ids" widget="kanban_activity"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Vista búsqueda                                                    -->
    <!-- ================================================================ -->
    <record id="view_service_request_search" model="ir.ui.view">
        <field name="name">service.request.search</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <search string="Buscar solicitudes">
                <field name="name" string="Referencia / Cliente / Título"
                       filter_domain="['|', '|', ('name', 'ilike', self), ('title', 'ilike', self), ('partner_id', 'ilike', self)]"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="type_id"/>
                <filter name="my_requests" string="Mis solicitudes" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter name="draft" string="Borrador" domain="[('state', '=', 'draft')]"/>
                <filter name="open" string="Abiertas"
                        domain="[('state', 'in', ['draft', 'pending', 'quoted'])]"/>
                <filter name="accepted" string="Aceptadas" domain="[('state', '=', 'accepted')]"/>
                <filter name="in_progress" string="En curso" domain="[('state', '=', 'in_progress')]"/>
                <filter name="done" string="Completadas" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="overdue" string="Vencidas"
                        domain="[('date_deadline', '&lt;', context_today().strftime('%Y-%m-%d')), ('state', 'in', ['draft', 'pending', 'quoted'])]"/>
                <filter name="urgent" string="Urgentes" domain="[('priority', '=', '3')]"/>
                <separator/>
                <filter name="healthy" string="Margen saludable" domain="[('margin_category', '=', 'healthy')]"/>
                <filter name="low_margin" string="Margen bajo/crítico"
                        domain="[('margin_category', 'in', ['low', 'critical', 'unprofitable'])]"/>
                <filter name="unprofitable" string="No rentables"
                        domain="[('margin_category', '=', 'unprofitable')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_partner" string="Cliente" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_type" string="Tipo de servicio" context="{'group_by': 'type_id'}"/>
                    <filter name="group_user" string="Responsable" context="{'group_by': 'user_id'}"/>
                    <filter name="group_margin" string="Categoría de margen" context="{'group_by': 'margin_category'}"/>
                    <filter name="group_priority" string="Prioridad" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Vistas de análisis (dashboard)                                   -->
    <!-- ================================================================ -->
    <record id="view_service_request_graph" model="ir.ui.view">
        <field name="name">service.request.graph</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <graph string="Rentabilidad" type="bar" sample="1">
                <field name="type_id"/>
                <field name="total_price" type="measure"/>
                <field name="margin_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_service_request_pivot" model="ir.ui.view">
        <field name="name">service.request.pivot</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <pivot string="Rentabilidad" sample="1">
                <field name="type_id" type="row"/>
                <field name="state" type="col"/>
                <field name="total_cost" type="measure"/>
                <field name="total_price" type="measure"/>
                <field name="margin_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ================================================================ -->
    <!-- Acciones                                                          -->
    <!-- ================================================================ -->

    <!-- Solicitudes (lista/kanban/form + análisis) -->
    <record id="action_service_request" model="ir.actions.act_window">
        <field name="name">Solicitudes</field>
        <field name="res_model">service.request</field>
        <field name="view_mode">tree,kanban,form,graph,pivot</field>
        <field name="search_view_id" ref="view_service_request_search"/>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primera solicitud de servicio
            </p>
            <p>
                Registra solicitudes técnicas, genera presupuestos y controla la
                rentabilidad de cada trabajo.
            </p>
        </field>
    </record>

    <!-- Tablero Kanban -->
    <record id="action_service_request_kanban" model="ir.actions.act_window">
        <field name="name">Tablero Kanban</field>
        <field name="res_model">service.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_service_request_search"/>
    </record>

    <!-- Panel / Dashboard analítico -->
    <record id="action_service_request_dashboard" model="ir.actions.act_window">
        <field name="name">Panel de rentabilidad</field>
        <field name="res_model">service.request</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_service_request_search"/>
        <field name="context">{'search_default_group_type': 1}</field>
    </record>

</odoo>
